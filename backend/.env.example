# Copy this file to ".env" and fill in your real key.
#   cp .env.example .env
#
# Triage prefers OpenRouter (free Qwen model), then Groq, then a keyword demo mode.

# Get a free key at https://openrouter.ai/keys  (starts with sk-or-...)
OPENROUTER_API_KEY=sk-or-your_key_here

# Optional: override the model id
# OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# Optional Groq fallback — https://console.groq.com/keys
# GROQ_API_KEY=gsk_your_key_here
